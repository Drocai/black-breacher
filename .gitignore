# ---- Godot 4 ----
# Engine cache — rebuilds automatically, must never be committed.
.godot/

# Export output and presets (export_presets.cfg can contain signing secrets).
export_presets.cfg

# Compiled translation binaries.
*.translation

# ---- Mono / C# build artifacts ----
.mono/
data_*/
mono_crash.*.json

# ---- Android build template artifacts ----
/android/

# ---- Meshy pipeline working dir (raw downloads; never commit secrets/large temp) ----
_meshy_out/
*.meshy_key
